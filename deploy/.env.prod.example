COMPOSE_PROJECT_NAME=igov2

# Images produced by GitHub Actions. Prefer an immutable sha-* tag after the first deploy.
IGO_FRONTEND_IMAGE=ghcr.io/<github-owner>/igov2-frontend:branch-main
IGO_BACKEND_IMAGE=ghcr.io/<github-owner>/igov2-backend:branch-main

HTTP_PORT=8081
CORS_ORIGIN=https://igo.example.go.id

DB_NAME=igopdf
DB_USER=igopdf
DB_PASSWORD=change-this-database-password

# At least 32 chars. Generate with: openssl rand -base64 48
SESSION_SECRET=change-this-to-a-long-random-secret-value

SESSION_TIMEOUT_HOURS=3

# Cookie 'Secure' flag. MUST be false while the app is reached over plain HTTP
# (no TLS) — otherwise the browser drops the session cookie and login bounces
# straight back to the login page. Set true ONLY once the browser reaches the
# app over HTTPS end-to-end. With TLS terminated at the SafeLine WAF / reverse
# proxy (browser->WAF HTTPS, WAF->app HTTP), keep this false unless the proxy
# forwards X-Forwarded-Proto=https and the app is configured to trust it.
SESSION_COOKIE_SECURE=false

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Reverse-proxy hops in front of the backend. The bundled compose nginx = 1.
# Add 1 per extra proxy (e.g. SafeLine WAF in front of nginx = 2). If this is
# wrong (or a proxy doesn't forward X-Forwarded-For), every user resolves to
# the proxy's IP and per-IP rate limits pool into one shared bucket.
TRUST_PROXY_HOPS=1
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
CAPTCHA_EXPIRY_MINUTES=5
LOG_LEVEL=info

# Server-side fallback for PDFs above 100 MB. The browser sends sequential
# resumable 25 MiB chunks, and the worker processes one job at a
# time; 500 MB-1 GB files are lossless-only to protect the 6 GB VM.
SERVER_COMPRESSION_ENABLED=true
CLIENT_COMPRESSION_MAX_BYTES=104857600
SERVER_BALANCED_MAX_BYTES=524288000
SERVER_COMPRESSION_MAX_BYTES=1073741824
COMPRESSION_UPLOAD_CHUNK_BYTES=26214400
COMPRESSION_UPLOAD_IDLE_TIMEOUT_MS=1800000
COMPRESSION_UPLOAD_MAX_AGE_MS=10800000
COMPRESSION_DISK_HEADROOM_MULTIPLIER=3
COMPRESSION_DISK_MINIMUM_FREE_BYTES=1073741824
COMPRESSION_JOB_TIMEOUT_MS=2700000
COMPRESSION_RETENTION_MS=900000
COMPRESSION_WORKER_POLL_MS=2000

# Only used when running: ./deploy.sh --seed-admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# ── Bulk user import ───────────────────────────────────────────────────────
# Optional. Default password applied to CSV/TXT-imported rows that have no
# password column. Leave empty to REQUIRE every imported row to carry its own
# password (there is no hardcoded fallback).
BULK_IMPORT_DEFAULT_PASSWORD=

# ── Active Directory / LDAP SSO ────────────────────────────────────────────
# When LDAP_ENABLED=true, an AD user who logs in with valid directory
# credentials is auto-provisioned locally (role 'user', password never stored).
# Local accounts (the seeded admin) are unaffected. Leave false for local-only.
LDAP_ENABLED=false

# Domain controller URL. Prefer ldaps://host:636 (encrypted) in production;
# ldap://host:389 is CLEARTEXT and only acceptable on a fully trusted LAN.
LDAP_URL=ldaps://dc01.example.internal:636

# Read-only service account used to search for a user's DN (search-then-bind).
# Accepts DOMAIN\user, user@domain (UPN), or a full DN. Must NOT be empty.
LDAP_BIND_DN=EXAMPLE\svc-igo-ldap
LDAP_BIND_PASSWORD=change-this-service-account-password

# Subtree to search. Narrow to a specific OU to restrict who may SSO.
LDAP_BASE_DN=OU=DomainUsers,DC=example,DC=internal
LDAP_LOGIN_FIELD=sAMAccountName
LDAP_TIMEOUT_MS=5000

# TLS (ldaps:// only). rejectUnauthorized=true verifies the DC certificate;
# set false for a self-signed cert, or point LDAP_TLS_CA_FILE at the internal
# CA cert (mounted into the backend container) to verify it properly.
LDAP_TLS_REJECT_UNAUTHORIZED=true
LDAP_TLS_CA_FILE=

# Set to TLSv1 only if the DC's LDAPS endpoint can't negotiate TLS 1.2 (Node
# otherwise resets the handshake even though openssl/ldapsearch connect).
# Leave empty for modern DCs.
LDAP_TLS_MIN_VERSION=
