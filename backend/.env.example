# IGO Backend Environment Variables
# Copy this file to .env and configure as needed.

# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=igopdf
DB_USER=igopdf
DB_PASSWORD=igopdf_password

# Session
SESSION_SECRET=change-me-in-production
SESSION_TIMEOUT_HOURS=3

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CAPTCHA
CAPTCHA_EXPIRY_MINUTES=5

# Auth
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Logging
LOG_LEVEL=info

# Server-side compression for PDFs above 100 MB. Keep disabled until the
# pdf-worker service and its storage volume are configured.
SERVER_COMPRESSION_ENABLED=false
COMPRESSION_JOBS_DIR=/var/lib/igo-jobs
CLIENT_COMPRESSION_MAX_BYTES=104857600
SERVER_BALANCED_MAX_BYTES=524288000
SERVER_COMPRESSION_MAX_BYTES=1073741824
COMPRESSION_UPLOAD_CHUNK_BYTES=26214400
COMPRESSION_UPLOAD_IDLE_TIMEOUT_MS=1800000
COMPRESSION_UPLOAD_MAX_AGE_MS=10800000
COMPRESSION_DISK_HEADROOM_MULTIPLIER=3
COMPRESSION_DISK_MINIMUM_FREE_BYTES=1073741824
COMPRESSION_JOB_TIMEOUT_MS=2700000
COMPRESSION_RETENTION_MS=900000
COMPRESSION_WORKER_POLL_MS=2000
