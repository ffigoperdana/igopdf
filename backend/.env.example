# IGO Backend Environment Variables
# Copy this file to .env and configure as needed.

# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=igopdf
DB_USER=igopdf
DB_PASSWORD=igopdf_password

# Session
SESSION_SECRET=change-me-in-production
SESSION_TIMEOUT_HOURS=3

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CAPTCHA
CAPTCHA_EXPIRY_MINUTES=5

# Auth
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Logging
LOG_LEVEL=info
